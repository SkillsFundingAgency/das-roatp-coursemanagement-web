@using SFA.DAS.Roatp.CourseManagement.Web.Infrastructure
@using SFA.DAS.Roatp.CourseManagement.Web.Models.ShortCourses.ManageShortCourses
@model ManageShortCoursesViewModel
@{
    ViewData["Title"] = $"Manage your {Model.ApprenticeshipTypeLowerPlural}";
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <h1 class="govuk-heading-xl margin-bottom-30" id="header-apprenticeshipUnit">Manage your @Model.ApprenticeshipTypeLowerPlural</h1>
        <p class="govuk-body">Use this section to add a new @Model.ApprenticeshipTypeLower, update its details or delete it. Any changes you make will update Find apprenticeship training.</p>
        <p class="govuk-body">
            <a href="@Model.AddAShortCourseLink" class="govuk-button">
                Add an @Model.ApprenticeshipTypeLower
            </a>
        </p>
        @if(Model.ShowShortCourseHeading)
        {
            <h2 class="govuk-heading-m">Your @Model.ApprenticeshipTypeLowerPlural</h2>
        }        
        
        <table class="govuk-table" aria-labelledby="course-list">
            <thead class="govuk-table__head govuk-visually-hidden">
                <tr class="govuk-table__row">
                    <th class="govuk-table__header govuk-!-font-size-24" scope="col">Courses</th>
                </tr>
            </thead>
            <tbody class="govuk-table__body">
                @foreach (var course in Model.ShortCourses)
                {
                    <tr class="govuk-table__row">
                        <td class="govuk-table__cell">
                            <div class="govuk-!-margin-top-1 govuk-!-margin-bottom-2">
                                <a class="govuk-link" href="@course.StandardUrl">
                                    @course.CourseDisplayName
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>
