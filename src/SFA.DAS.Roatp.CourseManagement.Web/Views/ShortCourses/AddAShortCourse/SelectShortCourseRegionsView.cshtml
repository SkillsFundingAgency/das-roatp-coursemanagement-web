@using SFA.DAS.Roatp.CourseManagement.Web.Models.ShortCourses.AddAShortCourse
@model SelectShortCourseRegionsViewModel
@{
    ViewBag.Title = "Select regions for course delivery";
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <partial name="_validationSummary" />
        <div class="govuk-caption-l">Add an @Model.ShortCourseBaseModel.ApprenticeshipTypeLower</div>
        <h1 class="govuk-heading-xl margin-bottom-30">Where can you deliver this training?</h1>
        <p class="govuk-body">You have told us you cannot deliver this training at an employer’s address anywhere in England.</p>
        <p class="govuk-body">Choose the regions where you can.</p>
        <form method="post" asp-route="@RouteNames.SelectShortCourseRegions" enctype="multipart/form-data" novalidate data="@Model">
            <hr class="govuk-section-break govuk-section-break--m govuk-section-break--visible">
            <div class="govuk-form-group" esfa-validation-marker-for="SelectedSubRegions">
                <span class="govuk-error-message" asp-validation-for="SelectedSubRegions" id="SelectedSubRegions"></span>
            </div>
            <fieldset class="govuk-fieldset">
                <ul class="govuk-list govuk-grid-row">
                    <li class="govuk-grid-column list-item-margin-bottom-30 list-item-margin-left-20">
                        <div class="govuk-checkboxes__item  govuk-checkboxes--small">
                            <input class="govuk-checkboxes__input" id="providerCourseStandardsCheckAll" name="providerCourseStandardsCheckAll" type="checkbox" value="0">
                            <label class="govuk-label govuk-checkboxes__label" for="providerCourseStandardsCheckAll">
                                Select all
                            </label>
                        </div>
                    </li>
                </ul>

            @foreach (var region in Model.SubregionsGroupedByRegions)
            {
                <h3 class="govuk-heading-m">@region.Key</h3>
                <ul class="govuk-list govuk-grid-row">
                    @foreach (var location in region.OrderBy(x => x.RegionName))
                    {
                        <li class="govuk-grid-column-one-half">
                            <div class="govuk-checkboxes__item  govuk-checkboxes--small">
                                <input class="govuk-checkboxes__input providerContactStandards" id="SelectedSubRegions-@location.Id" name="SelectedSubRegions" type="checkbox" value="@location.Id" asp-for="@location.IsSelected">
                                <label class="govuk-label govuk-checkboxes__label" for="SubRegions" asp-for="@location.SubregionName">
                                    @location.SubregionName
                                </label>
                            </div>
                        </li>
                    }
                </ul>
                <hr class="govuk-section-break govuk-section-break--m govuk-section-break--visible">
            }
            </fieldset>

            <div class="govuk-button-group">
                <button id="Continue" class="govuk-button" data-module="govuk-button" data-disable-on-submit="true">
                    @Model.SubmitButtonText
                </button>
            </div>
        </form>
    </div>
</div>