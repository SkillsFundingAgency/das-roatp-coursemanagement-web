@model SFA.DAS.Roatp.CourseManagement.Web.Models.ProviderContact.AddProviderContactCompleteViewModel

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <div class="govuk-panel govuk-panel--confirmation govuk-!-margin-bottom-6">
            <h1 class="govuk-panel__title">
                Contact details updated
            </h1>
        </div>
        <p class="govuk-body" asp-show="@Model.ShowBoth">
            The contact details for your chosen training is now <strong>@Model.EmailAddress</strong> and <strong>@Model.PhoneNumber</strong>.
        </p>

        <p class="govuk-body" asp-show="@Model.ShowEmailOnly">
            The contact details for your chosen training is now <strong>@Model.EmailAddress</strong>.
        </p>

        <p class="govuk-body" asp-show="@Model.ShowPhoneOnly">
            The contact details for your chosen training is now <strong>@Model.PhoneNumber</strong>.
        </p>  
        <div class="govuk-form-group" asp-show="Model.ShowStandards">
            <fieldset class="govuk-fieldset">
                <h2 class="govuk-heading-m">Apprenticeships</h2>
                <partial name="_CourseList" for="CheckedStandards" />
            </fieldset>
        </div>
        <div class="govuk-form-group" asp-show="Model.ShowApprenticeshipUnits">
            <fieldset class="govuk-fieldset">
                <h3 class="govuk-heading-m">Apprenticeship units</h3>
                <partial name="_CourseList" for="CheckedApprenticeshipUnits" />
            </fieldset>
        </div>
        <p class="govuk-body">
            We've updated your contact details on Find apprenticeship training.
        </p>
        <p class="govuk-body">
            We’ve also saved your details to use next time you add training.
        </p>
        <div class="govuk-button-group">
            <a id="Redirect" href="@Model.ManageCoursesUrl" class="govuk-button govuk-button">Go back to Manage your courses</a>
        </div>
    </div>
</div>