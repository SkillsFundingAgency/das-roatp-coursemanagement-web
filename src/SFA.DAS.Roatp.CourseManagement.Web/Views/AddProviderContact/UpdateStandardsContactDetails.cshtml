@model SFA.DAS.Roatp.CourseManagement.Web.Models.ProviderContact.ConfirmUpdateStandardsViewModel
@{
    ViewBag.Title = "Update existing standards with contact details";
}
<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <partial name="_validationSummary" />
        <div class="govuk-caption-l">Save contact details</div>
        <h1 asp-show="Model.EmailAddressAndPhoneNumberUpdate" class=" govuk-heading-xl">Update your contact details for standards and apprenticeship units</h1>
        <h1 asp-show="Model.EmailAddressOnlyUpdate" class=" govuk-heading-xl">Update your email address for standards and apprenticeship units</h1>
        <h1 asp-show="Model.PhoneNumberOnlyUpdate" class=" govuk-heading-xl">Update your phone number for standards and apprenticeship units</h1>
    </div>
</div>
<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <p asp-show="Model.EmailAddressOnlyUpdate" class="govuk-body">Saving a new email address to your standards and apprenticeship units will not remove any phone numbers associated with them.</p>
        <p asp-show="Model.PhoneNumberOnlyUpdate" class="govuk-body">Saving a new phone number to your standards and apprenticeship units will not remove any email addresses associated with them.</p>
        <dl class="govuk-summary-list">
            @if (Model.EmailAddressOnlyUpdate == true || Model.EmailAddressAndPhoneNumberUpdate == true)
            {
                <div class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">
                        Email address
                    </dt>
                    <dd class="govuk-summary-list__value">
                        @Model.EmailAddress
                    </dd>
                </div>
            }
            @if (Model.PhoneNumberOnlyUpdate == true || Model.EmailAddressAndPhoneNumberUpdate == true)
            {
                <div class="govuk-summary-list__row">
                    <dt class="govuk-summary-list__key">
                        Phone number
                    </dt>
                    <dd class="govuk-summary-list__value">
                        @Model.PhoneNumber
                    </dd>
                </div>
            }            
        </dl>
    </div>
</div>

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">                    
        <form method="post" enctype="multipart/form-data" novalidate>
            <input type="hidden" asp-for="@Model.EmailAddress" />
            <input type="hidden" asp-for="@Model.PhoneNumber" />
            <div esfa-validation-marker-for="HasOptedToUpdateExistingStandards" class="govuk-form-group">
                <fieldset class="govuk-fieldset">
                    <legend asp-show="Model.EmailAddressAndPhoneNumberUpdate" class="govuk-fieldset__legend govuk-fieldset__legend--m">Do you want to update any of your existing training with these contact details?</legend>
                    <legend asp-show="Model.EmailAddressOnlyUpdate" class="govuk-fieldset__legend govuk-fieldset__legend--m">Do you want to update any of your existing training with this email address?</legend>
                    <legend asp-show="Model.PhoneNumberOnlyUpdate" class="govuk-fieldset__legend govuk-fieldset__legend--m">Do you want to update any of your existing training with this phone number?</legend>
                    <div id="HasOptedToUpdateExistingStandards" class="govuk-radios" data-module="govuk-radios">
                        <span asp-validation-for="HasOptedToUpdateExistingStandards" class="govuk-error-message"></span>
                        <div class="govuk-radios__item">
                            <input class="govuk-radios__input" id="update-existing-standards-yes" type="radio" value="true"
                                   asp-for="HasOptedToUpdateExistingStandards" sfa-validationerror-class="form-control-error">
                            <label asp-show="Model.EmailAddressAndPhoneNumberUpdate" class="govuk-label govuk-radios__label" for="update-existing-standards-yes">
                                Yes, I want to choose which standards and apprenticeship units will use these details
                            </label>
                            <label asp-show="Model.EmailAddressOnlyUpdate" class="govuk-label govuk-radios__label" for="update-existing-standards-yes">
                                Yes, I want to choose which standards and apprenticeship units to update with this email address
                            </label>
                            <label asp-show="Model.PhoneNumberOnlyUpdate" class="govuk-label govuk-radios__label" for="update-existing-standards-yes">
                                Yes, I want to choose which standards and apprenticeship units to update with this phone number
                            </label>
                        </div>
                        <div class="govuk-radios__item">
                            <input class="govuk-radios__input" id="update-existing-standards-no" type="radio" value="false"
                                   asp-for="HasOptedToUpdateExistingStandards" sfa-validationerror-class="form-control-error">
                            <label asp-show="Model.EmailAddressAndPhoneNumberUpdate" class="govuk-label govuk-radios__label" for="update-existing-standards-no">
                                No, I just want to save them as an option for when I add a new type of training
                            </label>
                            <label asp-show="Model.EmailAddressOnlyUpdate" class="govuk-label govuk-radios__label" for="update-existing-standards-no">
                                No, I just want to save this email address as an option for when I add a new type of training
                            </label>
                            <label asp-show="Model.PhoneNumberOnlyUpdate" class="govuk-label govuk-radios__label" for="update-existing-standards-no">
                                No, I just want to save this phone number as an option for when I add a new type of training
                            </label>
                        </div>
                    </div>
                </fieldset>
            </div>
            <div class="govuk-button-group">
                <button id="submit" type="submit" class="govuk-button">Continue</button>
            </div>
        </form>
    </div>
</div>
