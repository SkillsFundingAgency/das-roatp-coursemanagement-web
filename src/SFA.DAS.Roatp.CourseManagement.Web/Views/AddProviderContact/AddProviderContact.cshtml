@model SFA.DAS.Roatp.CourseManagement.Web.Models.ProviderContact.AddProviderContactViewModel
@{
    ViewBag.Title = "Add provider contact";
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds govuk-!-margin-bottom-6">
        <partial name="_validationSummary" />
        <div class="govuk-caption-l">Save contact details</div>
        <h1 class="govuk-heading-xl margin-bottom-30">Save your contact details</h1>
        <div asp-show="Model.ExistingContactDetailsAvailable">
            <p class="govuk-body">Add an email address, phone number or both to use as your primary set of contact details. They will be shown on Find apprenticeship training and used by employers to contact you about training you offer.</p>
            <p class="govuk-body">We will save your contact details for next time you add a standard or apprenticeship unit. Once you have added them, you’ll be asked if you want to apply them to any or all of your existing training.</p>
        </div>
        <div asp-show="!Model.ExistingContactDetailsAvailable">
            <p class="govuk-body">Add an email address, phone number or both to use as your primary set of contact details.</p>
        </div>
    </div>
</div>
<div class="govuk-grid-row">
    <div class="govuk-grid-column-one-half">
        <form method="post" asp-route="@RouteNames.AddProviderContactDetails" enctype="multipart/form-data" novalidate>
            <div esfa-validation-marker-for="EmailAddress" class="govuk-form-group">
                <label class="govuk-label govuk-label--m" asp-for="EmailAddress" for="EmailAddress">
                    Email address
                </label>
                <div id="EmailAddress-hint" class="govuk-hint">
                    An email address for a person or team to speak to about your standards
                </div>
                <span asp-validation-for="EmailAddress" class="govuk-error-message"></span>
                <input asp-for="EmailAddress" id="EmailAddress" class="govuk-input" type="text" aria-describedby="EmailAddress-hint" maxlength="254" value="@Model.EmailAddress">
            </div>
            <div esfa-validation-marker-for="PhoneNumber" class="govuk-form-group">
                <label class="govuk-label govuk-label--m" asp-for="PhoneNumber" for="PhoneNumber">
                    Phone number
                </label>
                <div id="PhoneNumber-hint" class="govuk-hint">
                    A phone number for a person or team to speak to about your standards
                </div>
                <span asp-validation-for="PhoneNumber" class="govuk-error-message"></span>
                <input asp-for="PhoneNumber" id="PhoneNumber" class="govuk-input" type="text" aria-describedby="PhoneNumber-hint" maxlength="50" value="@Model.PhoneNumber">
            </div>
            
            <div class="govuk-button-group">
                <button id="Continue" class="govuk-button" data-module="govuk-button" data-disable-on-submit="true">
                    Continue
                </button>
            </div>
        </form>
    </div>
</div>
<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <details class="govuk-details">
            <summary class="govuk-details__summary">
                <span class="govuk-details__summary-text">
                    What happens if you only save an email address or phone number?
                </span>
            </summary>
        <div class="govuk-details__text">
            If you only save an email address and apply it to a standard, the phone number associated with the standard will stay the same.
        </div>
            <div class="govuk-details__text">
                If you only save a phone number and apply it to a standard, the email associated with the standard will stay the same.
            </div>
        </details>
    </div>
</div>