@model SFA.DAS.Roatp.CourseManagement.Web.Models.AddAStandard.CourseLocationAddViewModel
@{
    ViewBag.Title = "Training locations";
}
<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <partial name="_validationSummary" />
            <div class="govuk-caption-l">Add a standard</div>
        <h1 class="govuk-heading-xl">Venue and delivery</h1>
        <form method="post" asp-route="@RouteNames.PostAddStandardTrainingLocation" enctype="multipart/form-data" novalidate>
            <div esfa-validation-marker-for="TrainingVenueNavigationId" class="govuk-form-group">
                <label class="govuk-label" asp-for="TrainingVenueNavigationId">
                    Select the training venue for this standard.
                </label>
                <span asp-validation-for="TrainingVenueNavigationId" class="govuk-error-message"></span>
                <select asp-for="TrainingVenueNavigationId" asp-items="@Model.TrainingVenues" class="govuk-select">
                    <option value="" disabled selected>Choose a venue</option>
                </select>
            </div>

            <details class="govuk-details" data-module="govuk-details">
                <summary class="govuk-details__summary">
                    <span class="govuk-details__summary-text">
                        What if I want to add a training venue that isn't in this list?
                    </span>
                </summary>
                <div class="govuk-details__text">
                    You can only choose venues you have already registered when adding new training.
                </div>
                <div class="govuk-details__text">
                    If you want to use a venue that’s not in this list, you will need to register it after you finish adding this training.
                </div>
            </details>

            <div class="govuk-form-group" esfa-validation-marker-for="HasDayReleaseDeliveryOption">
                <fieldset class="govuk-fieldset">
                    <legend class="govuk-fieldset__legend">
                        Select the delivery method
                    </legend>
                    <span asp-validation-for="HasDayReleaseDeliveryOption" class="govuk-error-message"></span>
                    <ul class="govuk-list govuk-grid-row">
                        <li class="govuk-grid-column-one-half">
                            <div class="govuk-checkboxes__item  govuk-checkboxes--small">
                                <input class="govuk-checkboxes__input" id="HasDayReleaseDeliveryOption" name="HasDayReleaseDeliveryOption" type="checkbox" value="true" asp-for="HasDayReleaseDeliveryOption">
                                <label class="govuk-label govuk-checkboxes__label" for="HasDayReleaseDeliveryOption" asp-for="HasDayReleaseDeliveryOption">
                                    Day release
                                </label>
                            </div>
                        </li>
                        <li class="govuk-grid-column-one-half">
                            <div class="govuk-checkboxes__item  govuk-checkboxes--small">
                                <input class="govuk-checkboxes__input" id="HasBlockReleaseDeliveryOption" name="HasBlockReleaseDeliveryOption" type="checkbox" value="true" asp-for="HasBlockReleaseDeliveryOption">
                                <label class="govuk-label govuk-checkboxes__label" for="HasBlockReleaseDeliveryOption" asp-for="HasBlockReleaseDeliveryOption">
                                    Block release
                                </label>
                            </div>
                        </li>
                    </ul>
                </fieldset>
            </div>

            <div class="govuk-button-group">
                <button id="SaveAndContinue" class="govuk-button" data-module="govuk-button" data-disable-on-submit="true">
                    Save and continue
                </button>
            </div>
        </form>
    </div>
</div>