@using SFA.DAS.Roatp.CourseManagement.Web.Models.Standards
@using Microsoft.AspNetCore.Mvc.TagHelpers
@using SFA.DAS.DfESignIn.Auth.Extensions
@model SFA.DAS.Roatp.CourseManagement.Web.Models.ProviderLocations.ProviderLocationConfirmDeleteViewModel

@{
    ViewBag.Title = "Confirm deletion";
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <span class="govuk-caption-l">Training venue</span>
        <h1 class="govuk-heading-xl margin-bottom-30">Are you sure you want to delete this venue?</h1>
        
        <p class="govuk-body" asp-show="@Model.HasNoStandards">
            You do not deliver any training at this venue. If you delete this venue, you won't be able to add it as a training location.
        </p>
        
        <p class="govuk-body" asp-show="@Model.HasOneStandard">
            You deliver <strong>@Model.Standards.FirstOrDefault()!.CourseDisplayName</strong> at this venue.
            <p>
                This venue will no longer show as one of the training options for this training. <strong>@Model.Standards.FirstOrDefault()!.CourseDisplayName</strong> will not be deleted and your other training options will not be affected.
            </p>
            <div class="govuk-warning-text">
                <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
                <strong class="govuk-warning-text__text">
                    <span class="govuk-visually-hidden">Warning</span>
                    If you delete this venue, training linked to this venue will no longer show as being delivered here on Find apprenticeship training.
                </strong>
            </div>
        </p>
        
        <p class="govuk-body" asp-show="@Model.HasTwoOrMoreStandards">You deliver training at this venue.
            <h2 asp-show="Model.ShowStandards" class="govuk-heading-m">Apprenticeships</h2>

            <partial name="_CourseList" for="StandardList" />

            <h3 asp-show="Model.ShowApprenticeshipUnits" class="govuk-heading-m">Apprenticeship Units</h3>

            <partial name="_CourseList" for="ApprenticeshipUnitList" />
        
            <p class="govuk-body">This venue will no longer show as one of the training options for these courses. The training types will not be deleted and their other training options will not be affected.</p>
            <div class="govuk-warning-text">
                <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
                <strong class="govuk-warning-text__text">
                    <span class="govuk-visually-hidden">Warning</span>
                    If you delete this venue, training types linked to this venue will no longer show as being delivered here on Find apprenticeship training.
                </strong>
            </div>
        </p>

        <form method="post" asp-route="@RouteNames.GetConfirmDeleteLocation" enctype="multipart/form-data" novalidate>
            <div class="govuk-button-group">
                <button id="DeleteLocation" class="govuk-button govuk-button--warning" data-module="govuk-button" data-disable-on-submit="true">
                    Delete this venue
                </button>
        
                <a href="@Model.TrainingVenuesUrl" class="govuk-link">
                    Back to training venues
                </a>
        
            </div>
        </form>
    </div>
</div>