@using SFA.DAS.Roatp.CourseManagement.Web.Models.ShortCourses.AddAShortCourse
@model SaveShortCourseConfirmationViewModel
@{
    ViewData["Title"] = "Training saved";
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

        <div class="govuk-panel govuk-panel--confirmation govuk-!-margin-bottom-7">
            <h1 class="govuk-panel__title">
                Training saved
            </h1>
        </div>
        <p class="govuk-body">
            You have saved <strong>@Model.CourseName</strong> to your list of @Model.ApprenticeshipTypeLowerPlural. The contact details for this training will show on Find apprenticeship training, which is how employers will contact you about this training.
        </p>
        <p class="govuk-body">
            Next you can:
        </p>
        <ul class="govuk-list govuk-list--bullet">
            <li>
                go back to the <a class="govuk-link" href="@Model.DashboardLink"> dashboard</a>
            </li>
            <li>
                manage your other <a class="govuk-link" href="@Model.ManageTrainingTypeLink"> training types and venues</a>
            </li>
        </ul>
    </div>
</div>