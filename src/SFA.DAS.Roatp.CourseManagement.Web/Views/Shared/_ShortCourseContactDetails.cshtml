@using SFA.DAS.Roatp.CourseManagement.Web.Models.ShortCourses
@model ShortCourseContactDetailsViewModel

<form method="post" asp-route="@RouteNames.AddShortCourseContactDetails" enctype="multipart/form-data" novalidate>
    <div esfa-validation-marker-for="ContactUsEmail" class="govuk-form-group">
        <label class="govuk-label govuk-label--m" asp-for="ContactUsEmail">
            Email address
        </label>
        <div id="ContactUsEmail-hint" class="govuk-hint">
            An email address for a person or team to speak to about this @Model.ApprenticeshipTypeLower.
        </div>
        <span asp-validation-for="ContactUsEmail" class="govuk-error-message"></span>
        <input asp-for="ContactUsEmail" id="ContactUsEmail" class="govuk-input" type="text" aria-describedby="ContactUsEmail-hint" maxlength="254">
    </div>

    <div class="govuk-form-group" esfa-validation-marker-for="ContactUsPhoneNumber">
        <label class="govuk-label govuk-label--m" asp-for="ContactUsPhoneNumber">
            Phone number
        </label>
        <div id="ContactUsPhoneNumber-hint" class="govuk-hint">
            A phone number for a person or team to speak to about this @Model.ApprenticeshipTypeLower.
        </div>
        <span asp-validation-for="ContactUsPhoneNumber" class="govuk-error-message"></span>
        <input asp-for="ContactUsPhoneNumber" id="ContactUsPhoneNumber" class="govuk-input govuk-input--width-10" type="text" aria-describedby="ContactUsPhoneNumber-hint" maxlength="50">
    </div>

    <div class="govuk-form-group" esfa-validation-marker-for="StandardInfoUrl">
        <label class="govuk-label govuk-label--m" asp-for="StandardInfoUrl">
            Website
        </label>
        <div id="StandardInfoUrl-hint" class="govuk-hint">
            A link to a page on your website for this @Model.ApprenticeshipTypeLower.
        </div>
        <span asp-validation-for="StandardInfoUrl" class="govuk-error-message"></span>
        <input asp-for="StandardInfoUrl" id="StandardInfoUrl" class="govuk-input" type="text" aria-describedby="StandardInfoUrl-hint" maxlength="1000">
    </div>

    <div class="govuk-button-group">
        <button id="submit" type="submit" class="govuk-button">@Model.SubmitButtonText</button>
    </div>
</form>